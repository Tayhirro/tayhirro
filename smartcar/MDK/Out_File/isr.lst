   29          void UART1_Isr() interrupt 4
   30          {
   31   1          uint8 res;
   32   1        static uint8 dwon_count;
   33   1          if(UART1_GET_TX_FLAG)
   34   1          {
   35   2              UART1_CLEAR_TX_FLAG;
   36   2              busy[1] = 0;
   37   2          }
   38   1          if(UART1_GET_RX_FLAG)
   39   1          {
   40   2              UART1_CLEAR_RX_FLAG;
   41   2              res = SBUF;
   42   2              //程序自动下载
   43   2              if(res == 0x7F)
   44   2              {
   45   3                  if(dwon_count++ > 20)
   46   3                      IAP_CONTR = 0x60;
   47   3              }
   48   2              else
   49   2              {
   50   3                  dwon_count = 0;
   51   3              }
   52   2          }
   53   1      }
