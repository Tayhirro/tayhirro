   28          void UART1_Isr() interrupt 4
   29          {
   30   1          uint8 res;
   31   1        static uint8 dwon_count;
   32   1          if(UART1_GET_TX_FLAG)
   33   1          {
   34   2              UART1_CLEAR_TX_FLAG;
   35   2              busy[1] = 0;
   36   2          }
   37   1          if(UART1_GET_RX_FLAG)
   38   1          {
   39   2              UART1_CLEAR_RX_FLAG;
   40   2              res = SBUF;
   41   2              //程序自动下载
   42   2              if(res == 0x7F)
   43   2              {
   44   3                  if(dwon_count++ > 20)
   45   3                      IAP_CONTR = 0x60;
   46   3              }
   47   2              else
   48   2              {
   49   3                  dwon_count = 0;
   50   3              }
   51   2          }
   52   1      }
