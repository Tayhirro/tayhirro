   59          static void dl1a_simiic_delay(void)
   60          {
   61   1          uint16 j=DL1A_SOFT_IIC_DELAY;   
   62   1        while(j--);
   63   1      }
   64          
   65          //еҶ…йғЁдҪҝз”ЁпјҢз”ЁжҲ·ж— йңҖи°ғз”Ё
   66          static void dl1a_simiic_start(void)
   67          {
   68   1        DL1A_SDA_HIGH();
