  126          //еҸ‘йҖҒc(еҸҜд»ҘжҳҜж•°жҚ®д№ҹеҸҜжҳҜең°еқҖ)пјҢйҖҒе®ҢеҗҺжҺҘж”¶д»Һеә”зӯ”
  127          //дёҚиҖғиҷ‘д»Һеә”зӯ”дҪҚ
  128          //еҶ…йғЁдҪҝз”ЁпјҢз”ЁжҲ·ж— йңҖи°ғз”Ё
  129          static void dl1a_send_ch(uint8 c)
  130          {
  131   1        uint8 i = 8;
  132   1          while(i--)
  133   1          {
  134   2              if(c & 0x80)  DL1A_SDA_HIGH();//SDA иҫ“еҮәж•°жҚ®
  135   2              else      DL1A_SDA_LOW();
  136   2              c <<= 1;
  137   2              dl1a_simiic_delay();
  138   2              DL1A_SCL_HIGH();                //SCL жӢүй«ҳпјҢйҮҮйӣҶдҝЎеҸ·
  139   2              dl1a_simiic_delay();
  140   2              DL1A_SCL_LOW();                //SCL ж—¶й’ҹзәҝжӢүдҪҺ
  141   2          }
  142   1        dl1a_sccb_waitack();
  143   1      }
  144          
  145          
  146          //еӯ—иҠӮжҺҘж”¶зЁӢеәҸ
  147          //жҺҘж”¶еҷЁд»¶дј жқҘзҡ„ж•°жҚ®пјҢжӯӨзЁӢеәҸеә”й…ҚеҗҲ|дё»еә”зӯ”еҮҪж•°|дҪҝз”Ё
  148          //еҶ…йғЁдҪҝз”ЁпјҢз”ЁжҲ·ж— йңҖи°ғз”Ё
  149          static uint8 dl1a_read_ch(uint8 ack_x)
  150          {
  151   1          uint8 i;
  152   1          uint8 c;
  153   1          c=0;
  154   1          DL1A_SCL_LOW();
  155   1          dl1a_simiic_delay();
  156   1          DL1A_SDA_HIGH();             
  157   1      
  158   1          for(i=0;i<8;i++)
  159   1          {
  160   2              dl1a_simiic_delay();
  161   2              DL1A_SCL_LOW();         //зҪ®ж—¶й’ҹзәҝдёәдҪҺпјҢеҮҶеӨҮжҺҘж”¶ж•°жҚ®дҪҚ
  162   2              dl1a_simiic_delay();
  163   2              DL1A_SCL_HIGH();         //зҪ®ж—¶й’ҹзәҝдёәй«ҳпјҢдҪҝж•°жҚ®зәҝдёҠж•°жҚ®жңүж•Ҳ
  164   2              dl1a_simiic_delay();
  165   2              c<<=1;
  166   2              if(GET_DL1A_SDA) 
  167   2              {
  168   3                  c+=1;   //иҜ»ж•°жҚ®дҪҚпјҢе°ҶжҺҘж”¶зҡ„ж•°жҚ®еӯҳc
  169   3              }
  170   2          }
  171   1      
  172   1        DL1A_SCL_LOW();
  173   1        dl1a_simiic_delay();
  174   1        dl1a_simiic_sendack(ack_x);
  175   1        
  176   1          return c;
  177   1      }
