  259           float Filter(ADCN_enum adcn, ADCRES_enum resolution) {
  260   1        int     i, j;
  261   1        int     filter_temp, filter_sum = 0;
  262   1        int     filter_buf[FILTER_N];
  263   1        for (i = 0; i < FILTER_N; i++) {
  264   2          filter_buf[i] = adc_once(adcn,resolution);
  265   2        }
  266   1        // ˛ÉŃůÖµ´ÓĐˇµ˝´óĹĹÁĐŁ¨Ă°ĹÝ·¨Ł©
  267   1        for (j = 0; j < FILTER_N - 1; j++) {
  268   2          for (i = 0; i < FILTER_N - 1 - j; i++) {
  269   3            if (filter_buf[i] > filter_buf[i + 1]) {
  270   4              filter_temp = filter_buf[i];
  271   4              filter_buf[i] = filter_buf[i + 1];
  272   4              filter_buf[i + 1] = filter_temp;
  273   4            }
  274   3          }
  275   2        }
  276   1        for (i = 1; i < FILTER_N - 1; i++) filter_sum += filter_buf[i];
  277   1        return (float)filter_sum / (FILTER_N - 2);
