               //  @since      v1.0
               //  Sample usage:       
               //-------------------------------------------------------------------------------------------------------
             -------------
               static void icm20602_simiic_read_regs(uint8 dev_add, uint8 reg, uint8 *dat_add, uint32 num)
               {
                 icm20602_simiic_start();
                   icm20602_send_ch( (dev_add<<1) | 0x00);  //ЗЂЫЭЦїМўЕижЗМгаДЮЛ
C251 COMPILER V5.60.0,  SEEKFREE_ICM20602                                                  06/10/23  19:39:33  PAGE 5   

                 icm20602_send_ch( reg );          //ЗЂЫЭДгЛњМФДцЦїЕижЗ
               
                 
                 icm20602_simiic_start();
                 icm20602_send_ch( (dev_add<<1) | 0x01);  //ЗЂЫЭЦїМўЕижЗМгЖСЮЛ
                   while(--num)
                   {
                       *dat_add = icm20602_read_ch(ack); //ЖСШЁЪ§Он
                       dat_add++;
                   }
                   *dat_add = icm20602_read_ch(no_ack); //ЖСШЁЪ§Он
                 icm20602_simiic_stop();
               }
               
