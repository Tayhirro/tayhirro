   41   1          {
   42   2              UART1_CLEAR_RX_FLAG;
   43   2              res = SBUF;
   44   2              //程序自动下载
   45   2              if(res == 0x7F)
   46   2              {
   47   3                  if(dwon_count++ > 20)
   48   3                      IAP_CONTR = 0x60;
   49   3              }
   50   2              else
   51   2              {
   52   3                  dwon_count = 0;
   53   3              }
   54   2          }
   55   1      }
